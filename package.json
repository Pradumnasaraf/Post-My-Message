{
  "name": "post-my-message",
  "version": "1.6.0",
  "description": "Send sms or a beautiful quote to your friend by a simple POST request.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "format": "prettier --write .",
    "env": "cp .env.example .env",
    "lint": "eslint .",
    "dev:docker": "npm run env && npm run dev"
