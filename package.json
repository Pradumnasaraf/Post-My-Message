  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.8.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
